# Configuration backend - COPIER en .env et remplir avec les vraies valeurs
# NE JAMAIS committer le fichier .env réel !

# URL de connexion base de données
DATABASE_URL=

# Secret pour signer les JWT (générer une valeur aléatoire forte)
JWT_SECRET=

# Token interne d'authentification service-à-service
INTERNAL_TOKEN=

# Port d'écoute (optionnel, défaut 3000)
PORT=3000
